      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT COUNT(*)::bigint AS value FROM subscription_patterns WHERE status = 'confirmed'",
          "refId": "A"
        }
      ],
      "title": "Confirmed subscriptions",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "FlowFinancePostgreSQL" },
      "fieldConfig": { "defaults": { "unit": "currencyEUR" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT COALESCE(SUM(ABS(current_amount) * CASE WHEN interval_days <= 8 THEN 4.33 WHEN interval_days <= 16 THEN 2.165 WHEN interval_days <= 32 THEN 1 WHEN interval_days <= 95 THEN 0.33 WHEN interval_days >= 350 THEN 0.0833 ELSE 1 END), 0)::numeric AS value FROM subscription_patterns WHERE status = 'confirmed'",
          "refId": "A"
        }
      ],
      "title": "Monthly spend (normalized)",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "FlowFinancePostgreSQL" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT COUNT(*)::bigint AS value FROM subscription_patterns WHERE status = 'pending'",
          "refId": "A"
        }
      ],
      "title": "Pending review",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "FlowFinancePostgreSQL" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 4 },
      "id": 4,
      "options": { "showHeader": true },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT p.display_name, e.occurred_at::date AS date, e.previous_amount AS before_amount, e.amount AS after_amount, e.delta_pct FROM subscription_price_events e JOIN subscription_patterns p ON p.id = e.pattern_id WHERE e.event_type IN ('price_increase', 'price_decrease') AND e.occurred_at >= CURRENT_DATE - INTERVAL '90 days' ORDER BY e.occurred_at DESC LIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Price changes (90 days)",
      "type": "table"
    },
    {
      "datasource": { "type": "postgres", "uid": "FlowFinancePostgreSQL" },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 4 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT date_trunc('day', created_at) AS time, COUNT(*)::float AS value FROM subscription_patterns WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "New detections",
      "type": "timeseries"
    }
