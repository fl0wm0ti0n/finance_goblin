# Flow Finance AI — environment template (US-0001 / US-0010)
# Greenfield (bundled Firefly):  docker compose --profile minimal --profile bundled-firefly up --build
# Greenfield (app + Grafana only): docker compose --profile minimal up --build
# Omniflow host:  docker compose -f docker-compose.yml -f docker-compose.external.yml --profile external up -d

# ── Flow Finance AI external PostgreSQL (TimescaleDB-enabled) ──────────
# Bundled/minimal (greenfield): use host.docker.internal below.
# Omniflow external profile (DEC-0056 / BUG-0003): set DATABASE_HOST=postgres in operator .env —
# do NOT copy host.docker.internal; unreachable on traefik network → ~30s API 500 cascade.
DATABASE_HOST=host.docker.internal
# Omniflow external override (uncomment for financegnome deploy; see runbook § Omniflow mis-host):
# DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=flow_finance_ai
DATABASE_USER=finance
DATABASE_PASSWORD=change-me
# Optional: maintenance DB URL when app role lacks CREATEDB (shared homelab postgres).
# Full URL to postgres maintenance DB, e.g. postgres://admin:...@postgres:5432/postgres
# Never commit real credentials. Omit when DATABASE_USER has CREATEDB (greenfield dev/CI).
# DATABASE_BOOTSTRAP_URL=

# ── Flow Finance AI service ────────────────────────────────────────────
FLOW_PORT=8080
SYNC_INTERVAL_SECONDS=3600
RUST_LOG=info

# ── Firefly III (bundled-firefly profile only) ─────────────────────────
# NOT required for omniflow external profile — host container `firefly` is used instead.
# Omniflow external: FIREFLY_BASE_URL=http://firefly:8080 (overlay default)
# Public Firefly UI stays https://finance.omniflow.cc — PAT from Firefly profile → API tokens
FIREFLY_PORT=8081
FIREFLY_APP_KEY=base64:32RandomCharactersMinimumRequired==
FIREFLY_BASE_URL=http://firefly-iii:8080
# Required for omniflow external: non-empty PAT from Firefly → Profile → API tokens (never commit the value).
# Empty or whitespace-only is ignored at startup; sync fails fast with firefly_personal_access_token_missing.
FIREFLY_PERSONAL_ACCESS_TOKEN=
FIREFLY_DB_HOST=host.docker.internal
FIREFLY_DB_PORT=5432
FIREFLY_DB_DATABASE=firefly
FIREFLY_DB_USER=firefly
FIREFLY_DB_PASSWORD=change-me

# ── Omniflow external profile (US-0010 / BUG-0003 F2) ───────────────────
# Two-file merge; use profile external ONLY (never combine with minimal/standard/full/bundled-firefly).
# DATABASE_HOST must be postgres (Docker DNS on traefik network). Overlay default is postgres when unset;
# operator .env must not override with host.docker.internal (see runbook § Omniflow mis-host).
COMPOSE_FILE=docker-compose.yml:docker-compose.external.yml
COMPOSE_PROFILES=external
# Traefik router labels (docker-compose.external.yml) — optional overrides:
TRAEFIK_HOST=financegnome.omniflow.cc
TRAEFIK_MIDDLEWARE=auth
# Empty = Grafana internal-only (no public Traefik route). Set to expose, e.g. grafana-financegnome.omniflow.cc
GRAFANA_TRAEFIK_HOST=
# Database bootstrap (US-0012 / DEC-0058): backend auto-creates DATABASE_NAME on first start.
# TimescaleDB server packages on host Postgres remain an operator prerequisite — see runbook §1.
# When app role lacks CREATEDB on shared host postgres, set DATABASE_BOOTSTRAP_URL (admin URL above).
# Manual CREATE DATABASE is optional troubleshooting only; extension is attempted at bootstrap.
# When full profile on omniflow host (8090 used by firefly_product_manager):
STATS_FORECAST_PORT=8091
# ── Omniflow ML enablement (US-0013 / DEC-0076) ────────────────────────
# Opt-in: set FORECAST_ML_ENABLED=true after stats-forecast sidecar is healthy.
# Default-off preserves DEC-0049 — baseline forecast remains authoritative when unset.
FORECAST_ML_ENABLED=false
# Internal sidecar URL (container port 8090, not host remap):
STATS_FORECAST_URL=http://stats-forecast:8090
# Host debug port for sidecar health probe — default 8091 on omniflow (8090 clash with firefly_product_manager).
# Start external stack:
#   docker compose -f docker-compose.yml -f docker-compose.external.yml --profile external up -d

# ── OIDC (SPA + backend JWT validation) ────────────────────────────────
# Use external IdP or optional `oidc` Compose profile (Authentik)
OIDC_ISSUER_URL=https://your-idp.example.com/application/o/flow-finance/
OIDC_AUDIENCE=flow-finance-ai
# Frontend (Vite) — exposed to browser
VITE_OIDC_AUTHORITY=https://your-idp.example.com/application/o/flow-finance/
VITE_OIDC_CLIENT_ID=flow-finance-ai
# Local dev defaults; omniflow public URL registration (IdP admin):
VITE_OIDC_REDIRECT_URI=http://localhost:8080/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:8080/
# Omniflow production (register with IdP when auth enabled):
# VITE_OIDC_REDIRECT_URI=https://financegnome.omniflow.cc/callback
# VITE_OIDC_POST_LOGOUT_REDIRECT_URI=https://financegnome.omniflow.cc/
# VITE_OIDC_AUTHORITY=<same as OIDC_ISSUER_URL>
VITE_API_BASE_URL=

# App API JWT gate. Omniflow external profile defaults true (Traefik basic-auth on UI only).
# Set false when IdP + VITE_OIDC_* are fully configured.
AUTH_DEV_BYPASS=true

# ── Grafana ────────────────────────────────────────────────────────────
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# Browser-visible Grafana base URL (trailing slash required — DEC-0057 / US-0010 TRAEFIK_HOST).
# Omniflow default matches prefix-strip proxy at /analytics/grafana/
GF_SERVER_ROOT_URL=https://financegnome.omniflow.cc/analytics/grafana/
# Local dev override example:
# GF_SERVER_ROOT_URL=http://localhost:8080/analytics/grafana/
# Backend reverse proxy upstream (Docker default). Local dev without Compose: http://localhost:3000
GRAFANA_UPSTREAM=http://grafana:3000
# SPA iframe base path (build-time, same-origin proxy — DEC-0057)
VITE_GRAFANA_EMBED_BASE=/analytics/grafana
# Deprecated: external Grafana tab on Wealth — use in-app /analytics/portfolio instead
# VITE_GRAFANA_URL=http://localhost:3000

# ── AI provider (US-0008) — optional overrides ─────────────────────────
# AI_PROVIDER=openai
# AI_BASE_URL=http://ollama:11434/v1
# AI_MODEL=qwen2.5:14b
OPENAI_API_KEY=
# OLLAMA_API_KEY=  # optional dummy key for strict local gateways

# ── Optional profiles ──────────────────────────────────────────────────
REDIS_PORT=6379
OLLAMA_PORT=11434
AUTHENTIK_PORT=9000
AUTHENTIK_SECRET_KEY=
AUTHENTIK_DB_PASSWORD=authentik

# ── Crypto exchanges (US-0007) — read-only API keys, env only ─────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
BITUNIX_API_KEY=
BITUNIX_API_SECRET=
# Set false to disable Bitunix futures sync when credentials are present (DEC-0063)
BITUNIX_ENABLED_FUTURES=